{
  "buildCommand": "echo 'Static site - no build needed'",
  "outputDirectory": ".",
  "framework": "other",
  "rewrites": [
    {
      "source": "/game/(.*)",
      "destination": "/game/index.html"
    }
  ],
  "headers": [
    {
      "source": "/game/:path*",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "require-corp"
        }
      ]
    }
  ]
}
